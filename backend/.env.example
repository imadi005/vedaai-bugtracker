# Database (Neon / Supabase / local Postgres)
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/vedaai_bugs?schema=public"

# JWT
JWT_SECRET="your-super-secret-jwt-key-change-this-in-production"
JWT_EXPIRES_IN="7d"

# Server
PORT=5000
NODE_ENV=development
FRONTEND_URL="http://localhost:3000"

# AWS S3 (optional - for file attachments)
AWS_ACCESS_KEY_ID="your-aws-access-key"
AWS_SECRET_ACCESS_KEY="your-aws-secret-key"
AWS_REGION="ap-south-1"
AWS_S3_BUCKET="vedaai-bug-tracker"

# Email via Resend (optional)
RESEND_API_KEY="re_your_resend_api_key"
EMAIL_FROM="bugs@vedaai.com"

# Redis (Upstash) - for queues & sockets (optional for local dev)
REDIS_URL="redis://localhost:6379"
